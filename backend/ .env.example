# Django Settings
DEBUG=False
SECRET_KEY=django-insecure-replaced-by-generated-one-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1,your-production-domain.com

# Database Configuration
DB_NAME=cognitive_db
DB_USER=root
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=3306
# Or use DATABASE_URL
# DATABASE_URL=mysql://user:password@host:port/dbname

# Frontend Integration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
